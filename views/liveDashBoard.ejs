<meta http-equiv="Content-Security-Policy"
    content="default-src 'self'; script-src 'self' 'unsafe-inline' blob:; script-src-attr 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;">

<style>
    body {
        font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        background: #d0d0d0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
    }

    /* ───── CONTAINER ───── */
    .dashboard-container {
        position: relative;
        /* CRITICAL: Keeps sidebar inside the app frame */
        width: 100%;
        max-width: 420px;
        min-height: 92vh;
        background: #e0e0e0;
        border-radius: 28px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.12), 0 12px 40px rgba(0, 0, 0, 0.18);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    /* ───── SIDEBAR ALIGNMENT ───── */
    .overlay {
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        z-index: 10;
        border-radius: 28px;
        /* Matches container */
    }

    .sidebar {
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        width: 240px;
        /* Adjusted width for alignment */
        height: 100%;
        background: white;
        z-index: 11;
        box-shadow: 4px 0 15px rgba(0, 0, 0, 0.3);
        animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
        from {
            transform: translateX(-100%);
        }

        to {
            transform: translateX(0);
        }
    }

    .sidebar-header {
        background: #c0392b;
        color: white;
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .sidebar-header h3 {
        margin: 0;
        font-size: 18px;
    }

    .close-btn {
        cursor: pointer;
        font-size: 22px;
        font-weight: bold;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu li {
        padding: 16px 20px;
        border-bottom: 1px solid #f0f0f0;
        cursor: pointer;
        color: #333;
        font-weight: 500;
        transition: 0.2s;
    }

    .sidebar-menu li:hover {
        background: #f9f9f9;
        padding-left: 25px;
    }

    /* ───── REST OF YOUR UI ───── */
    .top-bar {
        background: #c0392b;
        color: white;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .menu-icon {
        font-size: 22px;
        cursor: pointer;
    }

    .logo img {
        height: 32px;
    }

    .wallet {
        background: white;
        border-radius: 20px;
        padding: 5px 10px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: #000;
    }

    .wallet button {
        background: #f39c12;
        border: none;
        color: white;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        cursor: pointer;
    }

    .sport-title {
        text-align: center;
        padding: 12px;
        font-weight: 600;
        color: #333;
        margin: 0;
    }

    .tabs {
        display: flex;
        justify-content: center;
        gap: 10px;
        padding: 10px;
    }

    .tab {
        border: none;
        padding: 8px 18px;
        border-radius: 20px;
        background: #dcdcdc;
        font-size: 14px;
        cursor: pointer;
        transition: 0.2s;
    }

    .tab.active {
        background: #c0392b;
        color: white;
        font-weight: 600;
    }

    .match-list {
        padding: 10px 14px;
        flex: 1;
        overflow-y: auto;
    }

    .match-card {
        background: #f5f5f5;
        border-radius: 16px;
        padding: 14px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8), 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: 0.15s;
    }

    .team img {
        width: 60px;
        height: 60px;
        object-fit: contain;
    }

    .match-center {
        text-align: center;
    }

    .score {
        background: #c0392b;
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .footer {
        background: #1a1a1a;
        color: rgba(255, 255, 255, 0.6);
        text-align: center;
        padding: 12px;
        font-size: 12px;
    }
</style>

<div class="dashboard-container">
    <div id="overlay" class="overlay"></div>
    <div id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <h3>Menu</h3>
            <span id="close-btn" class="close-btn">✖</span>
        </div>
        <ul class="sidebar-menu">
            <li>My Account</li>
            <li>About us</li>
            <li style="color: #c0392b;">Logout</li>
        </ul>
    </div>

    <div class="top-bar">
        <div id="menu-btn" class="menu-icon">☰</div>
        <div class="logo"> <img src="/Resource/logo2.png" /> </div>
        <div class="wallet"> <span>$100</span> <button>+</button> </div>
    </div>

    <h2 class="sport-title">Football</h2>

    <div class="tabs">
        <button id="upcoming-btn" class="tab">Upcoming</button>
        <button id="live-btn" class="tab active">Live</button>
        <button id="completed-btn" class="tab">Completed</button>
    </div>

    <div class="match-list">
        <% liveEvent.slice(0, 4).forEach((match, i)=> { %>
            <div class="match-card">
                <div class="team"> <img src='<%=srch[i]%>' alt="home-logo" /> </div>
                <div class="match-center">
                    <h3>VS</h3>
                    <div class="match-time">
                        <span class="score">
                            <%=match.scores[0].score%> - <%=match.scores[1].score%>
                        </span>
                    </div>
                </div>
                <div class="team"> <img src='<%= srca[i]%>' alt="away-logo" /> </div>
            </div>
            <% }) %>
    </div>

    <div class="footer"> © 2026 Abhijeet Gorhe 24×7 Pvt. Ltd All rights Reserved </div>
</div>

<script>
    // Element Selectors
    const menuBtn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-btn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('overlay');
    const upcomingBtn = document.getElementById('upcoming-btn');
    const completedBtn = document.getElementById('completed-btn');

    // Sidebar Logic
    menuBtn.addEventListener('click', () => {
        sidebar.style.display = 'block';
        overlay.style.display = 'block';
    });

    const hideSidebar = () => {
        sidebar.style.display = 'none';
        overlay.style.display = 'none';
    };

    closeBtn.addEventListener('click', hideSidebar);
    overlay.addEventListener('click', hideSidebar);

    // Navigation Logic
    if (completedBtn) {
        completedBtn.addEventListener('click', () => {
            window.location.href = '/dashboard/completeDashBoard';
        });
    }

    if (upcomingBtn) {
        upcomingBtn.addEventListener('click', () => {
            window.location.href = '/dashboard/upcomingDashboard';
        });
    }
</script>