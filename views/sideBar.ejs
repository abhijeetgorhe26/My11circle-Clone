<meta http-equiv="Content-Security-Policy"
    content="default-src 'self'; script-src 'self' 'unsafe-inline' blob:; script-src-attr 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;">

<style>
    body {
        font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        background: #d0d0d0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
    }

    /* ───── SIDEBAR STYLES ───── */
    .overlay {
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 10;
    }

    .sidebar {
        display: none;
        /* Hidden by default */
        position: absolute;
        top: 0;
        left: 0;
        width: 200px;
        height: 100%;
        background: white;
        z-index: 11;
        box-shadow: 2px 0 10px rgba(0, 0, 0, 0.2);
    }

    .sidebar-header {
        background: #c0392b;
        color: white;
        padding: 15px;
        display: flex;
        justify-content: flex-end;
    }

    .close-btn {
        cursor: pointer;
        font-size: 20px;
        font-weight: bold;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu li {
        padding: 15px 20px;
        border-bottom: 1px solid #eee;
        cursor: pointer;
        color: #333;
        font-weight: 500;
        transition: background 0.2s;
    }

    .sidebar-menu li:hover {
        background: #f5f5f5;
    }

    /* Container */
    .dashboard-container {
        position: relative;
        /* Essential for sidebar positioning */
        width: 100%;
        max-width: 420px;
        min-height: 92vh;
        background: #e0e0e0;
        border-radius: 28px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.12), 0 12px 40px rgba(0, 0, 0, 0.18);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    /* ───── HEADER ───── */
    .top-bar {
        background: #c0392b;
        color: white;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .menu-icon {
        font-size: 22px;
        cursor: pointer;
    }

    .logo img {
        height: 32px;
    }

    .wallet {
        background: white;
        border-radius: 20px;
        padding: 5px 10px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
    }

    .wallet span {
        color: #000;
    }

    .wallet button {
        background: #f39c12;
        border: none;
        color: white;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        cursor: pointer;
    }

    /* Title, Tabs, and Match List styles remain the same as your original */
    .sport-title {
        text-align: center;
        padding: 12px;
        font-weight: 600;
        color: #333;
    }

    .tabs {
        display: flex;
        justify-content: center;
        min-width: 270px;
        gap: 10px;
        padding-bottom: 10px;
    }

    .tab {
        border: none;
        padding: 6px 16px;
        border-radius: 20px;
        background: #dcdcdc;
        font-size: 14px;
        cursor: pointer;
        transition: 0.2s;
    }

    .tab.active {
        background: #c0392b;
        color: white;
        font-weight: 600;
    }

    .match-list {
        padding: 10px 14px;
        flex: 1;
        overflow-y: auto;
    }

    .match-card {
        background: #f5f5f5;
        border-radius: 16px;
        padding: 14px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8), 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: transform 0.15s ease;
    }

    .team img {
        width: 60px;
        height: 60px;
        object-fit: contain;
    }

    .match-center {
        text-align: center;
    }

    .match-center h3 {
        font-size: 16px;
        margin-bottom: 6px;
    }

    .score {
        background: #c0392b;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .footer {
        background: #1a1a1a;
        color: rgba(255, 255, 255, 0.6);
        text-align: center;
        padding: 12px;
        font-size: 12px;
    }
</style>

<div class="dashboard-container">
    <div id="overlay" class="overlay"></div>
    <div id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <span id="close-btn" class="close-btn">✖</span>
        </div>
        <ul class="sidebar-menu">
            <li>My Account</li>
            <li>About us</li>
            <li style="color: #c0392b;">Logout</li>
        </ul>
    </div>

    <div class="top-bar">
        <div id="menu-btn" class="menu-icon">☰</div>
        <div class="logo"> <img src="/Resource/logo2.png" /> </div>
        <div class="wallet"> <span>$100</span> <button>+</button> </div>
    </div>

    <h2 class="sport-title">Football</h2>
    <div class="tabs">
        <button id="upcoming-btn" class="tab">Upcoming</button>
        <button id="live-btn" class="tab">Live</button>
        <button class="tab active">Completed</button>
    </div>

    <div class="match-list">
        <% completeDashBoard.slice(0, 4).forEach((match, i)=> { %>
            <div class="match-card">
                <div class="team"> <img src='<%=srch[i]%>' /> </div>
                <div class="match-center">
                    <h3>VS</h3>
                    <div class="match-time">
                        <span class="score">
                            <%=match.scores[0].score%> - <%=match.scores[1].score%>
                        </span>
                    </div>
                </div>
                <div class="team"> <img src='<%= srca[i]%>' /> </div>
            </div>
            <% }) %>
    </div>

    <div class="footer"> © 2026 Abhijeet Gorhe 24×7 Pvt. Ltd All rights Reserved </div>
</div>

<script>
    const menuBtn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-btn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('overlay');

    const upcomingBtn = document.getElementById('upcoming-btn');
    const liveBtn = document.getElementById('live-btn');

    // Sidebar toggle logic
    menuBtn.addEventListener('click', () => {
        sidebar.style.display = 'block';
        overlay.style.display = 'block';
    });

    closeBtn.addEventListener('click', () => {
        sidebar.style.display = 'none';
        overlay.style.display = 'none';
    });

    overlay.addEventListener('click', () => {
        sidebar.style.display = 'none';
        overlay.style.display = 'none';
    });

    // Tab navigation logic
    liveBtn.addEventListener('click', function () {
        window.location.href = '/dashboard/liveDashBoard';
    });

    upcomingBtn.addEventListener('click', function () {
        window.location.href = '/dashboard/upcomingDashboard';
    });
</script>